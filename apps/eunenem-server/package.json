{
  "name": "eunenem-server",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "eunenem frontend — Hono serves SSR React with esbuild-bundled hydration. Side-deploy of the engine repo.",
  "scripts": {
    "dev": "concurrently -k -n build,server -c blue,magenta \"node --env-file-if-exists=.env build.mjs --watch\" \"node dev-server.mjs\"",
    "build": "node --env-file-if-exists=.env build.mjs",
    "start": "NODE_ENV=production tsx --env-file-if-exists=.env server.tsx",
    "typecheck": "tsc --noEmit",
    "auth-smoke": "tsx --env-file-if-exists=.env scripts/auth-smoke.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@opentelemetry/api": "^1.9.1",
    "@stripe/react-stripe-js": "^6.5.0",
    "@stripe/stripe-js": "^9.7.0",
    "@tanstack/react-query": "^5.100.14",
    "@trpc/client": "^11.17.0",
    "@trpc/react-query": "^11.17.0",
    "@trpc/server": "^11.17.0",
    "better-auth": "^1.6.12",
    "hono": "^4.6.14",
    "html-to-image": "^1.11.13",
    "kysely": "^0.28.7",
    "pg": "^8.20.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-easy-crop": "^6.0.2",
    "sonner": "^2.0.7",
    "stripe": "^18.0.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^9.1.0",
    "esbuild": "^0.24.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
