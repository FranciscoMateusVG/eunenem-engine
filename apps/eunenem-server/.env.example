# eunenem-server — local-dev environment (aperture-ht7sq).
#
# Copy to `.env` and replace every value. The server validates these at
# boot (apps/eunenem-server/server/auth/setup.ts) and throws on missing
# or malformed entries. Production deploys MUST override every value.

# BetterAuth signing key. ≥32 chars. Generate via `openssl rand -hex 32`
# or `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`.
# **NEVER commit the real value** — this dev placeholder is safe because
# nothing public-facing trusts it.
BETTER_AUTH_SECRET=dev-only-secret-min-32-chars-aaaaaaaaaaaaaaaaaaaaaa

# Public origin of the server. Used for cookie domain + trustedOrigins
# baseline. Dev default matches the `serve` port.
BETTER_AUTH_URL=http://localhost:3001

# Comma-separated allowlist of trusted origins (T6 from recon §4 — no
# wildcards). Append don't replace. For local dev, include any front-end
# port that hits this server cross-origin.
TRUSTED_ORIGINS=http://localhost:3001,http://localhost:5173

# Postgres connection string. Migrations live in the engine repo —
# run `pnpm db:migrate` from the engine root to create the schema
# (usuarios + contas + BetterAuth tables) before starting this server.
# Dev default points at the engine's docker-compose Postgres on 54320.
DATABASE_URL=postgresql://frame:frame@localhost:54320/frame

# Node environment. Controls cookie security (Secure flag) + log verbosity.
# Does NOT gate the payment-provider DI any longer (aperture-ozlcr) —
# that gate now checks STRIPE_SECRET_KEY presence (see Stripe block below).
NODE_ENV=development

# ── Stripe (aperture-xaha2 + aperture-24n36 + aperture-ozlcr) ──────────────
#
# Stripe-test-mode keys for visitor checkout (embedded ui_mode). The server
# adapter (PagamentoProviderStripe) requires SECRET_KEY at boot when
# NODE_ENV=production. The client bundle (esbuild build.mjs) inlines ONLY
# the PUBLISHABLE_KEY via `define`. WEBHOOK_SECRET is read by the webhook
# handler (/api/webhooks/stripe) for signature verification.
#
# **Payment-provider DI gate (aperture-ozlcr):** the server picks the
# real Stripe adapter whenever STRIPE_SECRET_KEY is non-empty (dev with
# test keys, prod with live keys). When the key is blank the fake adapter
# kicks in — `cs_fake_xxx` clientSecrets, no network. Drop test-mode keys
# into your `.env` to flip to the real Stripe path on next boot; clear
# them to return to the fake path.
#
# Local dev workflow (real Stripe end-to-end):
#   1. Get test-mode keys from https://dashboard.stripe.com/test/apikeys
#      Format: pk_test_... and sk_test_...
#   2. Run `stripe listen --forward-to localhost:3001/api/webhooks/stripe`
#      The Stripe CLI prints a one-time whsec_xxx — paste it as
#      STRIPE_WEBHOOK_SECRET below. (This secret is unique per `stripe listen`
#      session; it changes if you stop+restart the CLI.)
#   3. Restart the dev server so it picks up the new env.
#
# Local dev workflow (fake adapter, no Stripe account needed):
#   1. Leave STRIPE_SECRET_KEY blank. The fake adapter handles
#      criarSessaoCheckout + obterSessaoCheckout in-process. Useful for
#      fresh clones, offline work, and unit-test-style dev without the
#      Stripe iframe.
#
# Production deploy: configure a webhook endpoint in the Stripe Dashboard
# (test mode for staging, live mode for prod) and use its signing secret.
#
# These three placeholders are SAFE TO COMMIT — they're empty strings, not
# real keys. The boot validator does NOT require them when NODE_ENV !==
# production, so a fresh clone can `pnpm dev` without crashing.
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Auth hardening (aperture-uc2ix + aperture-3pqt7) ───────────────────────
#
# TRUSTED_HOP_COUNT: number of trusted reverse-proxy hops between the origin
# process and the public internet. Used by `trustedClientIp` to read the
# rightmost-N entries of X-Forwarded-For for a non-spoofable source IP.
#   - Dev (no proxy):                        0  (default)
#   - Single proxy (Dokploy/Nginx):          1
#   - Cloudflare → Nginx → app:              2
# Production MUST set >=1 — otherwise rate-limit + audit-log buckets all
# collapse to "unknown" and credential-stuffing detection is blind.
TRUSTED_HOP_COUNT=0

# LOG_PII_HASH_SALT: per-deployment salt for sha256-hashing client PII
# (email, IP) in structured logs + sessions.ip_address column. Rotating
# breaks log correlation across the rotation (intentional). Production
# MUST set this to ≥32 chars. Generate via:
#   openssl rand -hex 32
# Treat as tier-1 secret material alongside BETTER_AUTH_SECRET.
#
# **Dev mode (aperture-j0ccg):** if left empty when NODE_ENV !== production,
# the hashClientPII helper gracefully degrades and emits a clearly-marked
# `unhashed:<value>` instead of throwing. Zero-config dev sign-in still
# works; logs are obviously dev-only. Production boot still requires a real
# ≥32-char salt (ServerEnvSchema enforces it at boot, hashClientPII
# enforces it again at call time as belt-and-suspenders).
LOG_PII_HASH_SALT=
